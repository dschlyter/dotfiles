#!/bin/bash

# git resorb [branch-name | -suffix]
# Resorb (reverse sprout): cherry-pick commits from another branch that
# haven't been applied to the current branch yet. Uses `git cherry` to
# detect already-applied commits (works even after rebase/amend).
#
# With no argument: find all suffix branches of the current branch and
# resorb them all.

set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<'EOF'
Usage: git resorb [branch-name | -suffix]

Cherry-pick unapplied commits from another branch into the current branch.
Uses `git cherry` (patch-id matching) so it works even when branches have
been rebased or amended.

  branch-name    Resorb commits from this branch
  -suffix        Shorthand for <current-branch>-suffix
  (no args)      Auto-detect: resorb all suffix branches of current branch

Examples:
  git resorb feat-auth          # cherry-pick unapplied commits from feat-auth
  git resorb -auth              # same, if on branch "feat"
  git resorb                    # resorb all suffix branches (feat-auth, feat-tests, etc)

See also: git sprout, git fledge
EOF
    exit 0
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "HEAD" ]]; then
    echo "Error: not on a branch (detached HEAD)."
    exit 1
fi

# Resorb a single branch: cherry-pick its unapplied commits onto current branch
resorb_branch() {
    local other="$1"

    if ! git rev-parse --verify "$other" >/dev/null 2>&1; then
        echo "Error: branch '$other' does not exist."
        return 1
    fi

    # Find the merge base between current branch and the other branch
    local base
    base=$(git merge-base "$CURRENT_BRANCH" "$other" 2>/dev/null || true)
    if [[ -z "$base" ]]; then
        echo "Error: '$other' shares no history with '$CURRENT_BRANCH'."
        return 1
    fi

    # Use git cherry to find commits on other branch not yet applied here.
    # git cherry <upstream> <head> outputs "+ sha" for unapplied, "- sha" for applied.
    local unapplied=()
    while IFS= read -r line; do
        local sign=${line:0:1}
        local sha=${line:2}
        if [[ "$sign" == "+" ]]; then
            unapplied+=("$sha")
        fi
    done < <(git cherry "$CURRENT_BRANCH" "$other" "$base")

    if [[ ${#unapplied[@]} -eq 0 ]]; then
        echo "No unapplied commits on '$other' — nothing to resorb."
        return 0
    fi

    echo "Resorbing ${#unapplied[@]} commit(s) from '$other'..."
    for sha in "${unapplied[@]}"; do
        echo "  Cherry-picking $(git log --oneline -1 "$sha")"
        if ! GIT_COMMITTER_DATE="$(git log -1 --format=%cD "$sha")" git cherry-pick "$sha"; then
            echo ""
            echo "Cherry-pick failed. Resolve conflicts and run 'git cherry-pick --continue'."
            return 1
        fi
    done
    echo "Done — resorbed ${#unapplied[@]} commit(s) from '$other'."
}

if [[ $# -ge 1 ]]; then
    OTHER="$1"
    # If starts with "-", treat as suffix of current branch
    if [[ "$OTHER" == -* ]]; then
        OTHER="${CURRENT_BRANCH}${OTHER}"
    fi
    resorb_branch "$OTHER"
else
    # Auto-detect: find all local branches that are suffixes of current branch
    FOUND=()
    while IFS= read -r branch; do
        branch=$(echo "$branch" | xargs)  # trim whitespace
        if [[ "$branch" == "${CURRENT_BRANCH}-"* || "$branch" == "${CURRENT_BRANCH}/"* ]]; then
            FOUND+=("$branch")
        fi
    done < <(git branch --format='%(refname:short)')

    if [[ ${#FOUND[@]} -eq 0 ]]; then
        echo "No suffix branches found for '$CURRENT_BRANCH'."
        exit 1
    fi

    echo "Found ${#FOUND[@]} suffix branch(es): ${FOUND[*]}"
    echo ""
    for branch in "${FOUND[@]}"; do
        resorb_branch "$branch"
        echo ""
    done
fi
