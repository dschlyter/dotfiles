#!/bin/bash

# git fledge
# Fledge a sprouted branch that has matured into being squash-merged to master.
# Auto-detects a suffix branch whose upstream is gone (merged), then
# calls git pluck to remove its commits from the current branch.
#
# See also: git sprout, git pluck

set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    cat <<'EOF'
Usage: git fledge

Auto-detect a sprouted branch (suffix branch with upstream gone) and remove
its commits from the current branch via git pluck.

Examples:
  git fledge    # auto-detect and fledge sprouted branch

See also: git sprout, git pluck
EOF
    exit 0
fi

if [[ $# -gt 0 ]]; then
    echo "Error: git fledge takes no arguments. Use 'git pluck <branch>' instead."
    exit 1
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "HEAD" ]]; then
    echo "Error: not on a branch (detached HEAD)."
    exit 1
fi

# Auto-detect: find branches that are suffixes of current branch with upstream gone
echo "Looking for sprouted branches of '$CURRENT_BRANCH' with upstream gone..."
OTHER_BRANCH=""
while IFS= read -r branch; do
    if [[ "$branch" == "${CURRENT_BRANCH}-"* ]]; then
        OTHER_BRANCH="$branch"
        echo "Found: $branch"
        break
    fi
done < <(git branch --format='%(refname:short) %(upstream:track)' | awk '$2 == "[gone]" {print $1}')

if [[ -z "$OTHER_BRANCH" ]]; then
    echo "No sprouted branch found. Use 'git pluck <branch>' to remove commits from a specific branch."
    exit 1
fi

echo "Fledging '$OTHER_BRANCH' from '$CURRENT_BRANCH'..."
echo ""
git pluck "$OTHER_BRANCH"

# Clean up the sprouted branch
echo "Deleting fledged branch '$OTHER_BRANCH'"
git branch -D "$OTHER_BRANCH" || echo "Warning: could not delete branch (remove its worktree first)"
