// Place your key bindings in this file to override the defaults
// vscode_keybindings_linux.json also works on windows, but instead on install.sh: Shift-Ctrl P -> Open Keyboard Shortcuts (JSON), and copy-paste

// Finding command ids: Shift-Ctrl P -> Press Cogwheel -> Right click on command -> Copy Command ID

// https://code.visualstudio.com/api/references/when-clause-contexts

[
    {
        "key": "ctrl+shift+j",
        "command": "workbench.action.terminal.focus"
    },
    // fileView shortcuts
    {
        "key": "ctrl+n",
        "command": "explorer.newFile"
    },
    {
        "key": "ctrl+n",
        "command": "-workbench.action.files.newUntitledFile"
    },
    {
        "key": "ctrl+d",
        "command": "compareSelected",
        "when": "focusedView == 'workbench.explorer.fileView'"
    },
    // Tab shortcuts
    // Note to self: change split with Ctrl-1,2,3
    {
        "key": "alt+h",
        "command": "workbench.action.previousEditor"
    },
    {
        "key": "alt+l",
        "command": "workbench.action.nextEditor"
    },
    {
        "key": "alt+shift+h",
        "command": "workbench.action.moveEditorLeftInGroup"
    },
    {
        "key": "alt+shift+l",
        "command": "workbench.action.moveEditorRightInGroup"
    },
    {
        "key": "alt+j",
        "command": "workbench.action.focusNextGroup"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.focusPreviousGroup"
    },
    // Editor shortcuts
    {
        "key": "ctrl+cmd+l",
        "command": "gitlens.toggleFileBlame",
        "when": "editorTextFocus"
    },
    // Claude
    {
        "key": "ctrl+alt+space",
        "command": "claude-vscode.editor.open"
    },
]