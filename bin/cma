#!/usr/bin/env python3

import argparse
import subprocess
import sys
import os
import unittest
import json
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

from dotlib.json_file import modify_json, read_json, file_lock
from dotlib.util import print_table

SESSIONS_DIR = Path.home() / ".local" / "share" / "cma"
SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
SESSIONS_FILE = str(SESSIONS_DIR / "sessions.json")
OLD_SESSIONS_FILE = str(SESSIONS_DIR / "old_sessions.jsonl")

PROJECTS_DIR = Path.home() / ".claude" / "projects"
CMA_CACHE_DIR = Path.home() / ".cache" / "cma"


def main():
    # https://docs.python.org/3/library/argparse.html
    global_parser = argparse.ArgumentParser(description='Claude manager - utilities to manage Claude + tmux aware session tracking')

    global_parser.set_defaults(handler=lambda *args, **kwargs: global_parser.print_help())
    sub_ps = global_parser.add_subparsers()

    sp = sub_ps.add_parser('list', aliases=['l', 'ls'], help='list active claude sessions')
    sp.add_argument('-d', action='store_true', help='only show sessions in current directory')
    sp.add_argument('-s', action='store_true', help='only show sessions in current tmux session')
    sp.add_argument('-v', action='store_true', help='verbose: show session UUID and total age')
    sp.set_defaults(handler=list_sessions)

    sp = sub_ps.add_parser('watch', aliases=['w'], help='watch sessions (re-renders on change)')
    sp.add_argument('-d', action='store_true', help='only show sessions in current directory')
    sp.add_argument('-s', action='store_true', help='only show sessions in current tmux session')
    sp.add_argument('-v', action='store_true', help='verbose: show session UUID and total age')
    sp.set_defaults(handler=watch_sessions)

    sp = sub_ps.add_parser('next', aliases=['n'], help='switch to next waiting/done session')
    sp.set_defaults(handler=next_session)

    sp = sub_ps.add_parser('fork', aliases=['f'], help='fork a claude session from current window')
    sp.set_defaults(handler=fork_session)

    sp = sub_ps.add_parser('mark', aliases=['m'], help='mark a session as done')
    sp.add_argument('pane', nargs='?', default=None, help='pane id (default: current pane)')
    sp.set_defaults(handler=mark_session)

    sp = sub_ps.add_parser('who', help='print session id for current pane, a window, or list windows in a session')
    sp.add_argument('session', nargs='?', default=None, help='tmux session name')
    sp.add_argument('window', nargs='?', default=None, help='window name (if omitted, list all windows)')
    sp.add_argument('-s', action='store_true', help='use current tmux session')
    sp.add_argument('-v', action='store_true', help='verbose: show window name, pane id, session uuid, and title')
    sp.set_defaults(handler=who_session)

    sp = sub_ps.add_parser('drop', aliases=['d'], help='remove session from state or history')
    sp.add_argument('pane', nargs='?', default=None, help='pane id (default: current pane)')
    sp.add_argument('-s', '--session', metavar='NAME', default=None, help='drop entire tmux session (active + history)')
    sp.add_argument('-d', '--days', type=int, default=None, help='drop history entries older than N days')
    sp.set_defaults(handler=drop_session)

    sp = sub_ps.add_parser('old', help='list historical sessions (flat, by time)')
    sp.add_argument('-d', action='store_true', help='only show sessions from current directory')
    sp.add_argument('-s', action='store_true', help='only show sessions from current tmux session')
    sp.add_argument('-v', action='store_true', help='verbose: show session UUID')
    sp.set_defaults(handler=old_sessions)

    sp = sub_ps.add_parser('dead', help='list dead/historical sessions grouped by tmux session')
    sp.add_argument('-d', action='store_true', help='only show sessions from current directory')
    sp.add_argument('-s', action='store_true', help='only show sessions from current tmux session')
    sp.add_argument('-v', action='store_true', help='verbose: show individual sessions')
    sp.set_defaults(handler=dead_sessions)

    sp = sub_ps.add_parser('restore', help='restore dead sessions from a tmux session')
    sp.add_argument('tmux_session', nargs='?', default=None, help='tmux session name to restore (default: fzf select)')
    sp.add_argument('-t', metavar='TIME', default=None, help='cutoff: relative (e.g. 5m, 2h, 1d) or absolute (YYYY-MM-DD HH:MM)')
    sp.set_defaults(handler=restore_sessions)

    sp = sub_ps.add_parser('sync', help='backfill titles for sessions that have a session_id but no title')
    sp.add_argument('--overwrite', action='store_true', help='refresh titles even for sessions that already have one')
    sp.set_defaults(handler=sync_titles)

    sp = sub_ps.add_parser('clean', help='run cleanup (move stale sessions to archive)')
    sp.set_defaults(handler=clean_sessions)

    sp = sub_ps.add_parser('show', help='print conversation from a session log')
    sp.add_argument('session_id', nargs='?', default=None, help='session UUID or tmux_session:window (default: fzf select)')
    sp.add_argument('-p', '--pane', default=None, help='tmux pane id (e.g. 42 or %%42)')
    sp.add_argument('-v', action='count', default=0, help='verbose: -v expands tool calls, -vv shows full content')
    sp.set_defaults(handler=show_session)

    sp = sub_ps.add_parser('search', aliases=['s'], help='search session dumps with isearch')
    sp.add_argument('--dump-all', action='store_true', help='dump all new/updated sessions before searching')
    sp.add_argument('-r', action='store_true', help='resume the selected session in claude (cd to project dir)')
    sp.add_argument('-d', action='store_true', help='only search sessions from current directory')
    sp.set_defaults(handler=search_sessions)

    sp = sub_ps.add_parser('legacy', help='deprecated commands')
    sp.set_defaults(handler=lambda *args, **kwargs: sp.print_help())
    legacy_sub = sp.add_subparsers()

    legacy_sp = legacy_sub.add_parser('perms', help='list permissions in project settings')
    legacy_sp.set_defaults(handler=list_permissions)

    legacy_sp = legacy_sub.add_parser('lift', help='move last permission from project to global settings')
    legacy_sp.set_defaults(handler=lift)

    sp = sub_ps.add_parser('hook', help='hook handlers (called by Claude hooks)')
    sp.set_defaults(handler=lambda *args, **kwargs: sp.print_help())
    hook_sub = sp.add_subparsers()

    hook_sp = hook_sub.add_parser('install', help='install cma hooks into ~/.claude/settings.json')
    hook_sp.set_defaults(handler=hook_install)

    hook_sp = hook_sub.add_parser('uninstall', help='remove cma hooks from ~/.claude/settings.json')
    hook_sp.set_defaults(handler=hook_uninstall)

    hook_sp = hook_sub.add_parser('session-start', help='SessionStart: register session')
    hook_sp.set_defaults(handler=hook_session_start)

    hook_sp = hook_sub.add_parser('submit', help='UserPromptSubmit: mark session as working')
    hook_sp.set_defaults(handler=hook_submit)

    hook_sp = hook_sub.add_parser('notification', help='Notification/permission_prompt: mark session as waiting')
    hook_sp.set_defaults(handler=hook_notification)

    hook_sp = hook_sub.add_parser('stop', help='Stop: mark session as idle/done')
    hook_sp.set_defaults(handler=hook_stop)

    hook_sp = hook_sub.add_parser('session-end', help='SessionEnd: clean up session')
    hook_sp.set_defaults(handler=hook_session_end)

    hook_sp = hook_sub.add_parser('pane-focus', help='tmux pane-focus-in: transition done -> idle')
    hook_sp.set_defaults(handler=hook_pane_focus)

    parsed_args = global_parser.parse_args()
    # Note: All handlers must have **kwargs to handle global args
    try:
        parsed_args.handler(**parsed_args.__dict__)
    except Exception:
        # Hooks must not return non-zero; log to stderr for debugging
        if "hook" in sys.argv:
            import traceback
            print(traceback.format_exc(), file=sys.stderr)
        else:
            raise


def list_sessions(d=False, s=False, v=False, **kwargs):
    """List active claude sessions."""
    _modify_sessions(lambda data: _cleanup_stale(data))
    data = read_json(SESSIONS_FILE, default={"panes": {}})
    pane_info = _tmux_pane_info()
    # Filter to panes that still exist in tmux
    active_keys = [(k, v) for k, v in data["panes"].items() if v.get("tmux_pane") in pane_info]

    if d:
        cwd = os.getcwd()
        active_keys = [(k, v) for k, v in active_keys if v.get("cwd") == cwd]

    if s:
        try:
            current_session = sh_read("tmux display-message -p '#{session_name}'")
            active_keys = [(k, v) for k, v in active_keys
                           if pane_info.get(v.get("tmux_pane"), ("", "", ""))[0] == current_session]
        except subprocess.CalledProcessError:
            pass

    if not active_keys:
        print("No active sessions.")
        return

    # Group by session -> cwd -> entries
    from collections import defaultdict
    groups = defaultdict(lambda: defaultdict(list))
    for key, s in active_keys:
        pane = s.get("tmux_pane", f"%{key}")
        session_name, window_name, window_index = pane_info.get(pane, ("?", "?", "?"))
        window_name = _strip_emoji_prefix(window_name) or window_index
        cwd = _format_cwd(s.get("cwd", "?"))
        status_str = s.get("status", "?")
        icon = STATUS_ICONS.get(status_str, "")
        name_col = f"{icon} {window_name}"
        if v:
            status_col = status_str
            entry = [name_col, status_col, key,
                     _fmt_age(s.get("status_since")), _fmt_age(s.get("created_at")),
                     s.get("session_id", ""), s.get("title", "")]
        else:
            status_age = _fmt_age(s.get("status_since"), short=True)
            status_col = f"{status_str} {status_age}" if status_age else status_str
            entry = [name_col, status_col]
        sort_val = (int(window_index) if window_index.isdigit() else 9999, int(key) if key.isdigit() else 9999)
        groups[session_name][cwd].append((sort_val, entry))

    # Build hierarchical output with separate tables per cwd group
    for session_name in sorted(groups):
        print(session_name)
        cwd_groups = groups[session_name]
        for cwd in sorted(cwd_groups):
            print(f"  {cwd}")
            entries = sorted(cwd_groups[cwd], key=lambda x: x[0])
            rows = [["    " + e[0]] + e[1:] for _, e in entries]
            print_table(rows, sep="  ")


def watch_sessions(d=False, s=False, v=False, **kwargs):
    """Watch sessions, re-rendering when the state file changes."""
    import io
    last_mtime = None
    last_render = 0
    print("\033[?1049h", end="", flush=True)  # alternate screen buffer
    try:
        while True:
            try:
                mtime = os.stat(SESSIONS_FILE).st_mtime
            except FileNotFoundError:
                mtime = None

            now = time.monotonic()
            if mtime != last_mtime or now - last_render >= 60:
                last_mtime = mtime
                last_render = now
                # Capture list output
                buf = io.StringIO()
                old_stdout = sys.stdout
                sys.stdout = buf
                try:
                    list_sessions(d=d, s=s, v=v)
                finally:
                    sys.stdout = old_stdout
                output = buf.getvalue()
                # Clear screen and redraw
                print("\033[2J\033[H", end="")
                print(f"cma watch  {datetime.now().strftime('%H:%M:%S')}")
                print(output, end="", flush=True)

            time.sleep(1)
    except KeyboardInterrupt:
        pass
    finally:
        print("\033[?1049l", end="", flush=True)  # restore main screen


def _tmux_pane_info():
    """Get pane_id -> (session_name, window_name) mapping for all panes."""
    try:
        output = sh_read("tmux list-panes -a -F '#{pane_id}|||#{session_name}|||#{window_name}|||#{window_index}'")
        result = {}
        for line in output.strip().splitlines():
            pane_id, session_name, window_name, window_index = line.split("|||", 3)
            result[pane_id] = (session_name, window_name, window_index)
        return result
    except subprocess.CalledProcessError:
        return {}


def _fmt_age(iso_str, short=False):
    """Format an ISO timestamp as elapsed time, or empty if missing.
    short=True: largest unit only (e.g. '5h', '12m', '3d')
    short=False: d:hh:mm
    """
    if not iso_str:
        return ""
    try:
        dt = datetime.fromisoformat(iso_str)
        total_secs = int((datetime.now(timezone.utc) - dt).total_seconds())
        if total_secs < 0:
            total_secs = 0
        if short:
            if total_secs < 60:
                return f"{total_secs}s"
            total_mins = total_secs // 60
            if total_mins < 60:
                return f"{total_mins}m"
            hours = total_mins // 60
            if hours < 24:
                return f"{hours}h"
            return f"{hours // 24}d"
        total_mins = total_secs // 60
        days = total_mins // (60 * 24)
        hours = (total_mins % (60 * 24)) // 60
        mins = total_mins % 60
        return f"{days}:{hours:02d}:{mins:02d}"
    except ValueError:
        return ""


def _fmt_timestamp(iso_str):
    """Format an ISO timestamp as local YYYY-MM-DD HH:MM, or empty if missing."""
    if not iso_str:
        return ""
    try:
        dt = datetime.fromisoformat(iso_str).astimezone()
        return dt.strftime("%Y-%m-%d %H:%M")
    except ValueError:
        return ""


def _session_timestamp(sess):
    """Get the archived/status timestamp as epoch seconds, or 0 if missing."""
    iso_str = sess.get("archived_at") or sess.get("status_since") or sess.get("created_at")
    if not iso_str:
        return 0
    try:
        return datetime.fromisoformat(iso_str).timestamp()
    except ValueError:
        return 0


def _parse_time_cutoff(time_str):
    """Parse a relative (5m, 2h, 1d) or absolute (YYYY-MM-DD HH:MM) time string to epoch seconds."""
    import re
    m = re.fullmatch(r'(\d+)([smhd])', time_str.strip())
    if m:
        amount, unit = int(m.group(1)), m.group(2)
        multipliers = {'s': 1, 'm': 60, 'h': 3600, 'd': 86400}
        return datetime.now(timezone.utc).timestamp() - amount * multipliers[unit]
    try:
        dt = datetime.fromisoformat(time_str)
        if dt.tzinfo is None:
            dt = dt.astimezone()
        return dt.timestamp()
    except ValueError:
        return None


def next_session(**kwargs):
    """Switch to next waiting/done session, cycling back to origin when done."""
    _modify_sessions(lambda data: _cleanup_stale(data))
    data = read_json(SESSIONS_FILE, default={"panes": {}})

    # 1. Find next candidate — waiting before done, most recent first
    candidates = []
    for k, s in data["panes"].items():
        st = s.get("status")
        if st in ("waiting", "done"):
            priority = 0 if st == "waiting" else 1
            candidates.append((priority, s.get("status_since", ""), k, s))
    candidates.sort(key=lambda c: (c[0], c[1]), reverse=True)
    candidates.sort(key=lambda c: c[0])

    # 2. Load nav state (expire if > 1 minute old)
    nav = data.get("next")
    if nav:
        try:
            age = (datetime.now(timezone.utc) - datetime.fromisoformat(nav["timestamp"])).total_seconds()
            if age > 60:
                nav = None
        except (ValueError, KeyError):
            nav = None

    # 3. Nothing to do
    if not candidates and not nav:
        return

    # 4. No candidates — cycle complete, go back to origin
    if not candidates:
        original = nav["original_pane"]
        try:
            sh(f"tmux switch-client -t '{original}'")
        except subprocess.CalledProcessError:
            pass
        def clear_nav(data):
            data.pop("next", None)
        _modify_sessions(clear_nav)
        return

    # 5. Determine original pane: keep it if we're continuing a cycle
    current_pane = os.environ.get("TMUX_PANE", "")
    if nav and current_pane == nav.get("next_pane"):
        original_pane = nav["original_pane"]
    else:
        original_pane = current_pane

    # 6. Switch to next candidate
    _, _, pick_key, s = candidates[0]
    target_pane = s.get("tmux_pane", f"%{pick_key}")

    def save_nav(data):
        data["next"] = {
            "original_pane": original_pane,
            "next_pane": target_pane,
            "timestamp": datetime.now(timezone.utc).isoformat(),
        }
    _modify_sessions(save_nav)

    try:
        sh(f"tmux switch-client -t '{target_pane}'")
    except subprocess.CalledProcessError:
        def remove_stale(data):
            session = data["panes"].pop(pick_key, None)
            if session:
                _archive_sessions([session], status_override="abandoned")
        _modify_sessions(remove_stale)
        print(f"Removed stale session {target_pane}")


def drop_session(pane=None, session=None, days=None, **kwargs):
    """Remove sessions from state and/or history."""
    if session:
        _drop_by_session(session)
        return
    if days is not None:
        _drop_by_age(days)
        return

    key = pane if pane else _pane_key()
    if not key:
        print("No pane specified and TMUX_PANE not set.")
        return

    data = read_json(SESSIONS_FILE, default={"panes": {}})
    if key not in data.get("panes", {}):
        print(f"No session found for pane {key}")
        return

    def remove(data):
        data["panes"].pop(key, None)
    _modify_sessions(remove)
    _update_window_name(f"%{key}")
    print(f"Dropped session for pane {key}")


def _drop_by_session(session_name):
    """Drop all sessions (active + history) for a tmux session name."""
    count = 0
    def remove_active(data):
        nonlocal count
        to_remove = [k for k, s in data["panes"].items() if s.get("tmux_session") == session_name]
        for k in to_remove:
            del data["panes"][k]
        count += len(to_remove)
    _modify_sessions(remove_active)

    archived = _filter_archive(lambda r: r.get("tmux_session") != session_name)
    count += archived
    print(f"Dropped {count} sessions from '{session_name}'")


def _drop_by_age(days):
    """Drop history entries older than N days."""
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).timestamp()
    removed = _filter_archive(lambda r: _session_timestamp(r) >= cutoff)
    print(f"Dropped {removed} sessions older than {days} days")


def _filter_archive(keep_fn):
    """Rewrite archive keeping only lines where keep_fn(record) is True. Returns count removed."""
    if not os.path.exists(OLD_SESSIONS_FILE):
        return 0
    removed = 0
    with file_lock(OLD_SESSIONS_FILE):
        with open(OLD_SESSIONS_FILE, 'r') as f:
            lines = f.readlines()
        with open(OLD_SESSIONS_FILE, 'w') as f:
            for line in lines:
                try:
                    record = json.loads(line.strip())
                    if keep_fn(record):
                        f.write(line)
                    else:
                        removed += 1
                except json.JSONDecodeError:
                    f.write(line)
    return removed


def mark_session(pane=None, **kwargs):
    """Mark a session as done."""
    key = pane if pane else _pane_key()
    if not key:
        print("No pane specified and TMUX_PANE not set.")
        return

    def update(data):
        if key in data["panes"]:
            data["panes"][key]["status"] = "done"
            data["panes"][key]["status_since"] = datetime.now(timezone.utc).isoformat()
    _modify_sessions(update)
    _update_window_name(f"%{key}")


def who_session(session=None, window=None, s=False, v=False, **kwargs):
    """Print session id for current pane, a specific window, or list all windows in a tmux session."""
    if s and session is None:
        try:
            session = sh_read("tmux display-message -p '#{session_name}'")
        except subprocess.CalledProcessError:
            print("Not in a tmux session.", file=sys.stderr)
            sys.exit(1)

    if session is None:
        key = _pane_key()
        if not key:
            print("TMUX_PANE not set.", file=sys.stderr)
            sys.exit(1)
        data = read_json(SESSIONS_FILE, default={"panes": {}})
        pane = data.get("panes", {}).get(key)
        if not pane or not pane.get("session_id"):
            print(f"No session found for pane {key}.", file=sys.stderr)
            sys.exit(1)
        if v:
            pane_info = _tmux_pane_info()
            entry = pane_info.get(pane.get("tmux_pane", f"%{key}"), ("?", "?", "?"))
            clean_name = _strip_emoji_prefix(entry[1]) or entry[2]
            print_table([[clean_name, f"%{key}", pane["session_id"], pane.get("title", "")]], sep="  ")
        else:
            print(pane["session_id"])
        return

    data = read_json(SESSIONS_FILE, default={"panes": {}})
    pane_info = _tmux_pane_info()
    matches = []
    for k, sess in data.get("panes", {}).items():
        tmux_pane = sess.get("tmux_pane", f"%{k}")
        entry = pane_info.get(tmux_pane)
        if not entry:
            continue
        sess_name, win_name, win_index = entry
        if sess_name != session:
            continue
        clean_name = _strip_emoji_prefix(win_name) or win_index
        matches.append((k, clean_name, win_index, sess.get("session_id", ""), sess.get("title", "")))

    if not matches:
        print(f"No sessions found in tmux session '{session}'.", file=sys.stderr)
        sys.exit(1)

    if window is not None and not v:
        print(_resolve_tmux_session_id(f"{session}:{window}"))
        return

    if window is not None:
        matches = [m for m in matches if m[1] == window or m[2] == window]
        if not matches:
            print(f"No session found for window '{window}' in '{session}'.", file=sys.stderr)
            sys.exit(1)

    matches.sort(key=lambda m: (int(m[2]) if m[2].isdigit() else 9999))
    if v:
        rows = [[name, f"%{pane_key}", sid, title] for pane_key, name, _, sid, title in matches]
    else:
        rows = [[name, f"%{pane_key}", sid] for pane_key, name, _, sid, _ in matches]
    print_table(rows, sep="  ")


def _resolve_tmux_session_id(spec):
    """Resolve a 'tmux_session:window' spec to a claude session id. Errors on ambiguity."""
    parts = spec.split(':', 1)
    tmux_session = parts[0]
    window = parts[1] if len(parts) > 1 else None

    data = read_json(SESSIONS_FILE, default={"panes": {}})
    pane_info = _tmux_pane_info()
    matches = []
    for k, s in data.get("panes", {}).items():
        tmux_pane = s.get("tmux_pane", f"%{k}")
        entry = pane_info.get(tmux_pane)
        if not entry:
            continue
        sess_name, win_name, win_index = entry
        if sess_name != tmux_session:
            continue
        clean_name = _strip_emoji_prefix(win_name) or win_index
        if window is not None and clean_name != window and win_index != window:
            continue
        sid = s.get("session_id")
        if sid:
            matches.append((k, clean_name, sid))

    if not matches:
        print(f"No session found for '{spec}'.", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(f"Ambiguous: {len(matches)} sessions match '{spec}'. Use -p <pane_id> to select:", file=sys.stderr)
        for pane_key, name, sid in matches:
            print(f"  pane {pane_key}  {name}  {sid}", file=sys.stderr)
        sys.exit(1)
    return matches[0][2]


def _resolve_pane_session_id(pane):
    """Resolve a tmux pane id to a claude session id."""
    key = pane.lstrip('%')
    data = read_json(SESSIONS_FILE, default={"panes": {}})
    session = data.get("panes", {}).get(key)
    if not session or not session.get("session_id"):
        print(f"No session found for pane {key}.", file=sys.stderr)
        sys.exit(1)
    return session["session_id"]


def fork_session(**kwargs):
    """Fork a claude session from the current window."""
    data = read_json(SESSIONS_FILE, default={"panes": {}})
    pane_info = _tmux_pane_info()
    current_key = _pane_key()

    # Find the current window
    try:
        current_window = sh_read(f"tmux display-message -p '#{{window_id}}'")
        panes_output = sh_read(f"tmux list-panes -t '{current_window}' -F '#{{pane_id}}'")
        window_panes = {p.lstrip('%') for p in panes_output.strip().splitlines()}
    except subprocess.CalledProcessError:
        print("Error: not in a tmux session")
        return

    # Find sessions in this window with session_id, excluding current pane
    candidates = []
    for k, s in data.get("panes", {}).items():
        sid = s.get("session_id")
        if k in window_panes and sid and k != current_key:
            session_name, window_name, window_index = pane_info.get(s.get("tmux_pane", ""), ("?", "?", "?"))
            window_name = _strip_emoji_prefix(window_name) or window_index
            cwd = os.path.basename(s.get("cwd", "?"))
            candidates.append((k, s, f"{k}  {session_name}  {window_name}  {cwd}  {sid}"))

    if not candidates:
        print("No forkable sessions in this window.")
        return

    if len(candidates) == 1:
        _, s, _ = candidates[0]
        sid = s["session_id"]
    else:
        # Use fzf to select
        fzf_input = "\n".join(c[2] for c in candidates)
        try:
            selected = sh_read(f"echo '{fzf_input}' | fzf --prompt='Fork session> '")
            # Extract session_id (last field)
            sid = selected.strip().rsplit("  ", 1)[-1]
        except subprocess.CalledProcessError:
            return  # User cancelled fzf

    print(f"Forking session {sid}")
    os.execvp("claude", ["claude", "--resume", sid, "--fork-session"])


def old_sessions(d=False, s=False, v=False, **kwargs):
    """List historical sessions as a flat list ordered by time."""
    _modify_sessions(lambda data: _cleanup_stale(data))

    sessions = _read_old_sessions()
    if not sessions:
        print("No historical sessions.")
        return

    if d:
        cwd = os.getcwd()
        sessions = [s for s in sessions if s.get("cwd") == cwd]

    if s:
        try:
            current_session = sh_read("tmux display-message -p '#{session_name}'")
            sessions = [s for s in sessions if s.get("tmux_session") == current_session]
        except subprocess.CalledProcessError:
            pass

    if not sessions:
        print("No matching historical sessions.")
        return

    sessions.sort(key=lambda s: s.get("archived_at") or s.get("status_since") or "", reverse=True)
    rows = []
    for sess in sessions:
        status = sess.get("status", "?")
        tmux_name = sess.get("tmux_session", "?")
        window = sess.get("tmux_window", "?")
        cwd = _format_cwd(sess.get("cwd", "?"))
        timestamp = _fmt_timestamp(sess.get("archived_at") or sess.get("status_since"))
        row = [status, tmux_name, window, cwd, timestamp]
        if v:
            row.append(sess.get("session_id", ""))
            row.append(sess.get("title", ""))
        rows.append(row)
    print_table(rows, sep="  ")


def dead_sessions(d=False, s=False, v=False, **kwargs):
    """List dead/historical sessions grouped by tmux session name."""
    _modify_sessions(lambda data: _cleanup_stale(data))

    sessions = _read_old_sessions()
    if not sessions:
        print("No historical sessions.")
        return

    if d:
        cwd = os.getcwd()
        sessions = [s for s in sessions if s.get("cwd") == cwd]

    if s:
        try:
            current_session = sh_read("tmux display-message -p '#{session_name}'")
            sessions = [s for s in sessions if s.get("tmux_session") == current_session]
        except subprocess.CalledProcessError:
            pass

    if not sessions:
        print("No matching historical sessions.")
        return

    from collections import defaultdict
    groups = defaultdict(list)
    for sess in sessions:
        groups[sess.get("tmux_session", "unknown")].append(sess)

    def group_sort_key(name):
        return max(
            (s.get("archived_at") or s.get("status_since") or s.get("created_at") or "" for s in groups[name]),
            default=""
        )

    for tmux_name in sorted(groups, key=group_sort_key, reverse=True):
        group = groups[tmux_name]
        n_abandoned = sum(1 for s in group if s.get("status") == "abandoned")
        n_exited = sum(1 for s in group if s.get("status") == "exited")
        parts = []
        if n_abandoned:
            parts.append(f"{n_abandoned} abandoned")
        if n_exited:
            parts.append(f"{n_exited} exited")
        summary = ", ".join(parts) or f"{len(group)} sessions"
        print(f"{tmux_name}  ({summary})")

        if v:
            group.sort(key=lambda s: s.get("archived_at") or s.get("status_since") or "", reverse=True)
            rows = []
            for sess in group:
                cwd = _format_cwd(sess.get("cwd", "?"))
                window = sess.get("tmux_window", "?")
                status = sess.get("status", "?")
                timestamp = _fmt_timestamp(sess.get("archived_at") or sess.get("status_since"))
                row = [f"  {status}", window, cwd, timestamp]
                row.append(sess.get("session_id", ""))
                row.append(sess.get("title", ""))
                rows.append(row)
            print_table(rows, sep="  ")


def restore_sessions(tmux_session=None, t=None, **kwargs):
    """Restore dead sessions from a tmux session.

    Finds the latest archived timestamp in the group, then includes all sessions
    that exited within 60 seconds of it (i.e. a batch exit like a reboot).
    Use -t to override the cutoff with a relative (5m, 2h, 1d) or absolute timestamp.
    """
    _modify_sessions(lambda data: _cleanup_stale(data))

    sessions = _read_old_sessions()
    if not sessions:
        print("No restorable sessions.")
        return

    from collections import defaultdict
    groups = defaultdict(list)
    for s in sessions:
        groups[s.get("tmux_session", "unknown")].append(s)

    if not tmux_session:
        choices = sorted(groups.keys())
        fzf_input = "\n".join(f"{name}  ({len(groups[name])} sessions)" for name in choices)
        try:
            selected = sh_read(f"echo '{fzf_input}' | fzf --prompt='Restore session> '")
            tmux_session = selected.split("  ")[0]
        except subprocess.CalledProcessError:
            return

    if tmux_session not in groups:
        print(f"No restorable sessions for '{tmux_session}'")
        return

    group = groups[tmux_session]

    if t:
        cutoff = _parse_time_cutoff(t)
        if not cutoff:
            print(f"Invalid time format: {t}")
            return
        to_restore = [s for s in group if _session_timestamp(s) >= cutoff]
    else:
        latest = max(_session_timestamp(s) for s in group)
        cutoff = latest - 60
        to_restore = [s for s in group if _session_timestamp(s) >= cutoff]

    if not to_restore:
        print("No sessions match the time window.")
        return

    try:
        sh(f"tmux rename-session '{tmux_session}'")
    except subprocess.CalledProcessError:
        print(f"Warning: could not rename tmux session to '{tmux_session}'")

    def _sort_key(s):
        wi = s.get("tmux_window_index", "")
        pane = s.get("tmux_pane", "").lstrip("%")
        return (int(wi) if str(wi).isdigit() else 9999,
                int(pane) if pane.isdigit() else 9999)
    to_restore.sort(key=_sort_key)

    current_window = {}  # window_index -> pane count in that window
    for sess in to_restore:
        sid = sess.get("session_id")
        cwd = sess.get("cwd", os.getcwd())
        if not sid:
            continue
        wi = sess.get("tmux_window_index", "")
        window_name = sess.get("tmux_window", "") or _format_cwd(cwd)
        try:
            if wi not in current_window:
                sh(f"tmux new-window -n '{window_name}' -c '{cwd}' 'claude --resume {sid}'")
                current_window[wi] = 1
            else:
                split = "-h" if current_window[wi] == 1 else "-v"
                sh(f"tmux split-window {split} -c '{cwd}' 'claude --resume {sid}'")
                current_window[wi] += 1
        except subprocess.CalledProcessError:
            print(f"Failed to create pane for session {sid}")

    print(f"Restored {len(to_restore)} sessions from '{tmux_session}'")


def sync_titles(overwrite=False, **kwargs):
    """Backfill titles for all active and archived sessions that have a session_id but no title."""
    count = 0

    def _should_sync(session):
        return session.get("session_id") and (overwrite or not session.get("title"))

    # Active sessions
    def update_active(data):
        nonlocal count
        for k, s in data["panes"].items():
            if _should_sync(s):
                title = _get_session_title(s["session_id"])
                if title:
                    s["title"] = title
                    count += 1
    _modify_sessions(update_active)

    # Archived sessions
    if os.path.exists(OLD_SESSIONS_FILE):
        with file_lock(OLD_SESSIONS_FILE):
            with open(OLD_SESSIONS_FILE, 'r') as f:
                lines = f.readlines()
            with open(OLD_SESSIONS_FILE, 'w') as f:
                for line in lines:
                    try:
                        record = json.loads(line.strip())
                        if _should_sync(record):
                            title = _get_session_title(record["session_id"])
                            if title:
                                record["title"] = title
                                count += 1
                        f.write(json.dumps(record) + "\n")
                    except json.JSONDecodeError:
                        f.write(line)

    print(f"Updated {count} session titles.")


def clean_sessions(**kwargs):
    """Explicitly run stale session cleanup."""
    _modify_sessions(lambda data: _cleanup_stale(data))
    print("Cleanup complete.")


STATUS_ICONS = {"done": "🔴", "waiting": "🔴", "working": "🟡", "idle": "🟢"}
STATUS_PRIORITY = {"done": 0, "waiting": 0, "working": 1, "idle": 2}
ALL_ICONS = set(STATUS_ICONS.values())


def _format_cwd(cwd):
    """Format cwd for display. Detects worktree paths and shows as repo:worktree."""
    parts = cwd.split("/.claude/worktrees/")
    if len(parts) == 2:
        repo = os.path.basename(parts[0])
        worktree = parts[1].rstrip("/")
        return f"{repo}:{worktree}"
    return os.path.basename(cwd)


def _strip_emoji_prefix(name):
    """Remove status emoji prefix from a window name."""
    for emoji in ALL_ICONS:
        if name.startswith(emoji):
            return name[len(emoji):].lstrip()
    return name


def _update_window_name(pane_id=None):
    """Update the window name emoji for the window containing the given pane."""
    if not pane_id:
        pane_id = os.environ.get("TMUX_PANE", "")
    if not pane_id:
        return

    try:
        # Get window id and current name for this pane
        info = sh_read(f"tmux display-message -p -t '{pane_id}' '#{{window_id}}|||#{{window_name}}'")
        parts = info.split("|||", 1)
        window_id = parts[0]
        window_name = parts[1] if len(parts) > 1 else ""
        # Get all panes in this window
        panes_output = sh_read(f"tmux list-panes -t '{window_id}' -F '#{{pane_id}}'")
        window_panes = {p.lstrip('%') for p in panes_output.strip().splitlines()}
    except subprocess.CalledProcessError:
        return

    # Find worst status among registered panes in this window
    data = read_json(SESSIONS_FILE, default={"panes": {}})
    worst_status = None
    worst_priority = 999
    for key, s in data.get("panes", {}).items():
        if key in window_panes:
            st = s.get("status", "idle")
            p = STATUS_PRIORITY.get(st, 999)
            if p < worst_priority:
                worst_priority = p
                worst_status = st

    base_name = _strip_emoji_prefix(window_name)

    icon = STATUS_ICONS.get(worst_status)
    if icon:
        new_name = f"{icon} {base_name}" if base_name else icon
    else:
        new_name = base_name

    if new_name != window_name:
        try:
            sh(f"tmux rename-window -t '{window_id}' '{new_name}'")
        except subprocess.CalledProcessError:
            pass


HOOKS = {
    "SessionStart": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook session-start", "timeout": 5}],
    },
    "UserPromptSubmit": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook submit", "timeout": 5}],
    },
    "Notification": {
        "matcher": "permission_prompt",
        "hooks": [{"type": "command", "command": "cma hook notification", "timeout": 5}],
    },
    "Stop": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook stop", "timeout": 5}],
    },
    "StopFailure": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook stop", "timeout": 5}],
    },
    "PostToolUseFailure": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook stop", "timeout": 5}],
    },
    "SessionEnd": {
        "matcher": "",
        "hooks": [{"type": "command", "command": "cma hook session-end", "timeout": 5}],
    },
}

def _modify_claude_hooks(action):
    """Install or uninstall cma hooks in ~/.claude/settings.json.
    action: 'install' or 'uninstall'. Returns (changed, skipped) event lists."""
    settings_path = Path.home() / ".claude" / "settings.json"
    with open(settings_path, 'r') as f:
        settings = json.load(f)

    hooks = settings.setdefault("hooks", {})
    changed = []
    skipped = []

    for event, entry in HOOKS.items():
        existing = hooks.get(event, [])
        our_cmds = {h["command"] for h in entry["hooks"]}
        has_ours = any(
            h["command"] in our_cmds
            for rule in existing
            for h in rule.get("hooks", [])
        )

        if action == "install":
            if has_ours:
                skipped.append(event)
            else:
                existing.append(entry)
                hooks[event] = existing
                changed.append(event)
        elif action == "uninstall":
            if not has_ours:
                skipped.append(event)
            else:
                hooks[event] = [
                    rule for rule in existing
                    if not any(h["command"] in our_cmds for h in rule.get("hooks", []))
                ]
                if not hooks[event]:
                    del hooks[event]
                changed.append(event)

    if changed:
        with open(settings_path, 'w') as f:
            json.dump(settings, f, indent=2)

    return changed, skipped


TMUX_CONF = Path.home() / ".tmux.conf"
TMUX_HOOK_LINES = [
    "# Claude session manager - transition \"done\" -> \"idle\" when pane gets focus",
    "set-hook -g after-select-pane 'run-shell -b \"TMUX_PANE=#{pane_id} cma hook pane-focus\"'",
    "set-hook -g after-select-window 'run-shell -b \"TMUX_PANE=#{pane_id} cma hook pane-focus\"'",
    "set-hook -g client-session-changed 'run-shell -b \"TMUX_PANE=#{pane_id} cma hook pane-focus\"'",
]
TMUX_HOOK_MARKER = "cma hook pane-focus"


def _modify_tmux_hooks(action):
    """Add or remove cma lines in .tmux.conf. Returns 'installed'/'removed'/'already'/'not present'."""
    if not TMUX_CONF.exists():
        if action == "install":
            TMUX_CONF.write_text("\n".join(TMUX_HOOK_LINES) + "\n")
            return "installed"
        return "not present"

    content = TMUX_CONF.read_text()
    has_hook = TMUX_HOOK_MARKER in content

    if action == "install":
        if has_hook:
            return "already present"
        insert_block = "\n".join(TMUX_HOOK_LINES)
        TMUX_CONF.write_text(content.rstrip("\n") + "\n\n" + insert_block + "\n")
        return "installed"
    elif action == "uninstall":
        if not has_hook:
            return "not present"
        new_lines = [l for l in content.split("\n") if TMUX_HOOK_MARKER not in l and l not in TMUX_HOOK_LINES]
        TMUX_CONF.write_text("\n".join(new_lines))
        return "removed"


def hook_install(**kwargs):
    """Install cma hooks."""
    changed, skipped = _modify_claude_hooks("install")
    if changed:
        print(f"Claude hooks installed: {', '.join(changed)}")
    if skipped:
        print(f"Claude hooks already present: {', '.join(skipped)}")

    result = _modify_tmux_hooks("install")
    print(f"Tmux hooks: {result}")


def hook_uninstall(**kwargs):
    """Remove cma hooks."""
    changed, skipped = _modify_claude_hooks("uninstall")
    if changed:
        print(f"Claude hooks removed: {', '.join(changed)}")
    if skipped:
        print(f"Claude hooks not present: {', '.join(skipped)}")

    result = _modify_tmux_hooks("uninstall")
    print(f"Tmux hooks: {result}")


def hook_session_start(**kwargs):
    """Register a new session."""
    input_data = json.loads(sys.stdin.read())
    session_id = input_data.get('session_id')
    if not session_id:
        return

    key = _pane_key()
    tmux_pane = os.environ.get("TMUX_PANE", "unknown")
    cwd = os.environ.get("CLAUDE_WORKING_DIRECTORY", os.getcwd())
    pane_info = _tmux_pane_info()
    pane_entry = pane_info.get(tmux_pane, ("unknown", "", ""))
    tmux_session = pane_entry[0]
    tmux_window = _strip_emoji_prefix(pane_entry[1]) or pane_entry[2]
    tmux_window_index = pane_entry[2]

    def update(data):
        data["panes"][key or session_id[:12]] = {
            "session_id": session_id,
            "tmux_pane": tmux_pane,
            "tmux_session": tmux_session,
            "tmux_window": tmux_window,
            "tmux_window_index": tmux_window_index,
            "cwd": cwd,
            "status": "idle",
            "created_at": datetime.now(timezone.utc).isoformat(),
        }
    _modify_sessions(update)
    _update_window_name()


def hook_submit(**kwargs):
    input_data = json.loads(sys.stdin.read())
    session_id = input_data.get("session_id", "")
    key = _pane_key()
    if not key:
        return

    def update(data):
        _ensure_pane(data, key)
        data["panes"][key]["status"] = "working"
        data["panes"][key]["status_since"] = datetime.now(timezone.utc).isoformat()
        if session_id and data["panes"][key].get("session_id") != session_id:
            data["panes"][key]["session_id"] = session_id
    _modify_sessions(update)
    _update_window_name()


def hook_notification(**kwargs):
    _update_pane_status("waiting")
    _update_window_name()
    _alert_sound()


def hook_stop(**kwargs):
    key = _pane_key()
    if not key:
        return
    is_focused = _is_pane_focused()

    def update(data):
        _ensure_pane(data, key)
        data["panes"][key]["status"] = "idle" if is_focused else "done"
        data["panes"][key]["status_since"] = datetime.now(timezone.utc).isoformat()
        _sync_title_if_missing(data["panes"][key])
    _modify_sessions(update)
    _update_window_name()
    if not is_focused:
        _alert_sound()
    _dump_session_for_pane(key)


def hook_pane_focus(**kwargs):
    """Tmux after-select-pane: transition done -> idle for the focused pane."""
    key = _pane_key()
    if not key:
        return

    def update(data):
        pane = data["panes"].get(key)
        if pane and pane.get("status") == "done":
            pane["status"] = "idle"
            pane["status_since"] = datetime.now(timezone.utc).isoformat()
    _modify_sessions(update)
    _update_window_name()


def hook_session_end(**kwargs):
    """Archive session as 'exited' and remove from active state."""
    key = _pane_key()
    if not key:
        return

    def update(data):
        session = data["panes"].pop(key, None)
        if session:
            _sync_title_if_missing(session)
            _archive_sessions([session], status_override="exited")
    _modify_sessions(update)
    _update_window_name()


def _alert_sound():
    """Play a notification sound on macOS. No-op if no tmux session or non-macOS."""
    if not _pane_key():
        return
    if sys.platform != "darwin":
        return
    try:
        subprocess.Popen(["afplay", "/System/Library/Sounds/Glass.aiff"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        pass


def _update_pane_status(status_value):
    """Set status on the current pane's session."""
    key = _pane_key()
    if not key:
        return
    def update(data):
        _ensure_pane(data, key)
        data["panes"][key]["status"] = status_value
        data["panes"][key]["status_since"] = datetime.now(timezone.utc).isoformat()
    _modify_sessions(update)


def _pane_key():
    """Get the pane key (numeric part of TMUX_PANE) for the current pane."""
    tmux_pane = os.environ.get("TMUX_PANE", "")
    if not tmux_pane:
        return None
    return tmux_pane.lstrip('%')


def _is_pane_focused():
    """Check if the current pane is visible and focused by the user."""
    pane = os.environ.get("TMUX_PANE", "")
    if not pane:
        return False
    try:
        pane_info = sh_read(f"tmux display-message -p -t '{pane}' '#{{pane_active}}#{{window_active}} #{{session_name}}'")
        flags, pane_session = pane_info.split(" ", 1)
        if flags != "11":
            return False
        # Check if the client is actually viewing this session
        client_session = sh_read("tmux display-message -p '#{client_session}'")
        return pane_session == client_session
    except subprocess.CalledProcessError:
        return False


def _modify_sessions(fn):
    """Read-modify-write the sessions file. fn receives the full data dict."""
    modify_json(SESSIONS_FILE, fn, default={"panes": {}})


def _ensure_pane(data, key):
    """Ensure a pane entry exists, creating a minimal one if needed."""
    if key not in data["panes"]:
        tmux_pane = os.environ.get("TMUX_PANE", f"%{key}")
        pane_info = _tmux_pane_info()
        pane_entry = pane_info.get(tmux_pane, ("unknown", "", ""))
        data["panes"][key] = {
            "tmux_pane": tmux_pane,
            "tmux_session": pane_entry[0],
            "tmux_window": _strip_emoji_prefix(pane_entry[1]) or pane_entry[2],
            "tmux_window_index": pane_entry[2],
            "cwd": os.environ.get("CLAUDE_WORKING_DIRECTORY", os.getcwd()),
            "status": "idle",
            "created_at": datetime.now(timezone.utc).isoformat(),
        }


def _cleanup_stale(data):
    """Remove stale panes and refresh tmux_session/tmux_window for live ones. Mutates data."""
    pane_info = _tmux_pane_info()
    try:
        pane_output = sh_read("tmux list-panes -a -F '#{pane_id}'")
        active_panes = {p.lstrip('%') for p in pane_output.strip().splitlines()}
    except subprocess.CalledProcessError:
        return

    stale = []
    for k, s in data["panes"].items():
        if k not in active_panes:
            stale.append(k)
        else:
            tmux_pane = s.get("tmux_pane", f"%{k}")
            entry = pane_info.get(tmux_pane)
            if entry:
                s["tmux_session"] = entry[0]
                s["tmux_window"] = _strip_emoji_prefix(entry[1]) or entry[2]
                s["tmux_window_index"] = entry[2]

    if stale:
        stale_sessions = [data["panes"][k] for k in stale]
        for s in stale_sessions:
            _sync_title_if_missing(s)
        _archive_sessions(stale_sessions, status_override="abandoned")
        for k in stale:
            del data["panes"][k]


def _archive_sessions(sessions, status_override=None):
    """Append sessions to old_sessions.jsonl, deduplicating by session_id."""
    if not sessions:
        return
    new_ids = {s.get("session_id") for s in sessions if s.get("session_id")}
    with file_lock(OLD_SESSIONS_FILE):
        if new_ids and os.path.exists(OLD_SESSIONS_FILE):
            with open(OLD_SESSIONS_FILE, 'r') as f:
                lines = f.readlines()
            with open(OLD_SESSIONS_FILE, 'w') as f:
                for line in lines:
                    try:
                        record = json.loads(line.strip())
                        if record.get("session_id") not in new_ids:
                            f.write(line)
                    except json.JSONDecodeError:
                        f.write(line)
        with open(OLD_SESSIONS_FILE, 'a') as f:
            for s in sessions:
                record = dict(s)
                record["archived_at"] = datetime.now(timezone.utc).isoformat()
                if status_override:
                    record["status"] = status_override
                f.write(json.dumps(record) + "\n")


def _read_old_sessions():
    """Read all archived sessions from JSONL file."""
    if not os.path.exists(OLD_SESSIONS_FILE):
        return []
    sessions = []
    with file_lock(OLD_SESSIONS_FILE):
        with open(OLD_SESSIONS_FILE, 'r') as f:
            for line in f:
                line = line.strip()
                if line:
                    sessions.append(json.loads(line))
    return sessions


#
# Session Titles
#


def _get_session_title(session_id):
    """Extract the ai-title from a session's JSONL log (last one wins, as it may be updated)."""
    jsonl_path = _find_session_jsonl(PROJECTS_DIR, session_id)
    if not jsonl_path:
        return None
    title = None
    try:
        with open(jsonl_path, 'r') as f:
            for line in f:
                obj = json.loads(line)
                if obj.get("type") == "ai-title":
                    title = obj.get("aiTitle")
    except (json.JSONDecodeError, OSError):
        pass
    return title


def _sync_title_if_missing(session):
    """Populate title from log if missing and session_id is available. Mutates session."""
    sid = session.get("session_id")
    if sid and not session.get("title"):
        title = _get_session_title(sid)
        if title:
            session["title"] = title


#
# Session Reading and Searching
#


def show_session(session_id=None, pane=None, v=0, **kwargs):
    """Print a human-readable conversation from a session's JSONL log."""
    if pane:
        session_id = _resolve_pane_session_id(pane)
    elif not session_id:
        session_id = _fzf_select_session(PROJECTS_DIR)
        if not session_id:
            return
    elif ':' in session_id:
        session_id = _resolve_tmux_session_id(session_id)

    jsonl_path = _find_session_jsonl(PROJECTS_DIR, session_id)
    if not jsonl_path:
        print(f"No log file found for session {session_id}")
        return

    for line in _render_session(jsonl_path, verbosity=v):
        print(line)


def search_sessions(dump_all=False, r=False, d=False, **kwargs):
    """Search session dumps with isearch."""
    if dump_all:
        _dump_all_sessions()

    if d:
        dir_name = os.path.basename(os.getcwd())
        search_dir = CMA_CACHE_DIR / dir_name
        if not search_dir.exists():
            print(f"No cached sessions for '{dir_name}'.")
            return
    else:
        search_dir = CMA_CACHE_DIR

    try:
        selected = sh_read(f"cd {_shell_quote(str(search_dir))} && isearch .")
    except subprocess.CalledProcessError:
        return
    if not selected:
        return

    selected_path = (search_dir / selected).resolve()
    session_id = _extract_session_id(selected_path.stem)

    if r:
        jsonl_path = _find_session_jsonl(PROJECTS_DIR, session_id)
        if jsonl_path:
            project_dir = _project_dir_to_cwd(jsonl_path.parent.name)
            os.chdir(project_dir)
        os.execvp("claude", ["claude", "--resume", session_id])
    else:
        print(session_id)


def _fzf_select_session(projects_dir):
    """Let user pick a session via fzf from all JSONL files."""
    entries = []
    for jsonl_path in projects_dir.rglob("*.jsonl"):
        sid = jsonl_path.stem
        project = jsonl_path.parent.name
        mtime = datetime.fromtimestamp(jsonl_path.stat().st_mtime)
        first_user_msg = ""
        try:
            with open(jsonl_path, 'r') as f:
                for file_line in f:
                    obj = json.loads(file_line)
                    if obj.get("type") == "user":
                        content = obj.get("message", {}).get("content", "")
                        if isinstance(content, str) and not content.startswith("<"):
                            first_user_msg = content[:80].replace("\n", " ")
                            break
        except (json.JSONDecodeError, OSError):
            pass
        entries.append((mtime, sid, project, first_user_msg))

    entries.sort(reverse=True)
    fzf_lines = "\n".join(
        f"{e[1]}  {e[0].strftime('%Y-%m-%d %H:%M')}  {e[2]}  {e[3]}"
        for e in entries
    )
    try:
        selected = sh_read(f"printf '%s' {_shell_quote(fzf_lines)} | fzf --prompt='Session> '")
        return selected.split("  ")[0].strip()
    except subprocess.CalledProcessError:
        return None


def _find_session_jsonl(projects_dir, session_id):
    """Find the JSONL file for a given session ID."""
    for jsonl_path in projects_dir.rglob(f"{session_id}.jsonl"):
        return jsonl_path
    return None


def _render_session(jsonl_path, verbosity=0, color=True):
    """Yield human-readable lines from a session JSONL file."""
    with open(jsonl_path, 'r') as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            yield from _render_entry(obj, verbosity=verbosity, color=color)


def _render_entry(obj, verbosity=0, color=True):
    """Yield human-readable lines for a single JSONL entry."""
    msg_type = obj.get("type", "")
    uncapped = verbosity >= 2
    g = "\033[32m" if color else ""
    y = "\033[33m" if color else ""
    r = "\033[0m" if color else ""

    if msg_type == "user":
        content = obj.get("message", {}).get("content", "")
        if isinstance(content, str):
            text = _extract_user_text(content)
            if not text:
                return
            for line in text.splitlines():
                yield f"{g}>>> {line}{r}"
            yield ""
        elif isinstance(content, list):
            user_lines = []
            result_lines = []
            for block in content:
                if not isinstance(block, dict):
                    continue
                if block.get("type") == "text":
                    text = _extract_user_text(block.get("text", ""))
                    if text:
                        for line in text.splitlines():
                            user_lines.append(f"{g}>>> {line}{r}")
                elif block.get("type") == "image":
                    user_lines.append(f"{g}>>> [image]{r}")
                elif block.get("type") == "tool_result" and verbosity >= 1:
                    result_lines.extend(_render_tool_result(block, uncapped=uncapped, color=color))
            if user_lines:
                yield from user_lines
                yield ""
            if result_lines:
                yield from result_lines

    elif msg_type == "assistant":
        content = obj.get("message", {}).get("content", [])
        if not isinstance(content, list):
            return
        out = []
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "text":
                text = block["text"].strip()
                if text:
                    out.append(text)
            elif block.get("type") == "tool_use":
                out.append(f"  {y}[tool: {block.get('name', '?')}]{r}")
                if verbosity >= 1:
                    out.extend(_render_tool_input(block, uncapped=uncapped, color=color))
        if out:
            yield from out
            yield ""


def _extract_user_text(raw):
    """Extract displayable user text, handling command tags and system content."""
    import re
    text = raw.strip()
    if not text:
        return ""
    # Command invocations: extract from <command-args> if present
    if text.startswith("<command-message>") or text.startswith("<command-name>"):
        m = re.search(r'<command-args>(.*?)</command-args>', text, re.DOTALL)
        cmd_m = re.search(r'<command-name>(.*?)</command-name>', text)
        cmd = cmd_m.group(1).strip() if cmd_m else ""
        args = m.group(1).strip() if m else ""
        return f"{cmd} {args}".strip() if cmd or args else ""
    # Skip system-injected content (local-command-caveat, system-reminder, etc.)
    if text.startswith("<local-command-") or text.startswith("<system-reminder"):
        return ""
    # Skip skill/long injected content
    if text.startswith("Base directory for this skill:"):
        return ""
    if text.startswith("[Image: source:"):
        return ""
    return text


def _render_tool_input(block, uncapped=False, color=True):
    """Yield tool call input lines in verbose mode."""
    name = block.get("name", "")
    inp = block.get("input", {})
    dim = "\033[2m" if color else ""
    reset = "\033[0m" if color else ""

    if name == "Bash":
        cmd = inp.get("command", "")
        if cmd:
            for line in cmd.splitlines():
                yield f"  {dim}$ {line}{reset}"
    elif name == "Read":
        yield f"  {dim}{inp.get('file_path', '')}{reset}"
    elif name in ("Write", "Edit"):
        yield f"  {dim}{inp.get('file_path', '')}{reset}"
        content = inp.get("content") or inp.get("new_string") or ""
        if content:
            yield from _render_capped_lines(content, prefix="  | ", cap=20, uncapped=uncapped, color=color)
    elif name == "Agent":
        prompt = inp.get("prompt", "")
        if prompt:
            yield from _render_capped_lines(prompt, prefix="  | ", cap=10, uncapped=uncapped, color=color)
    else:
        for key, val in inp.items():
            val_str = str(val)
            if not uncapped and len(val_str) > 200:
                val_str = val_str[:200] + "..."
            yield f"  {dim}{key}: {val_str}{reset}"


def _render_tool_result(block, uncapped=False, color=True):
    """Yield tool result output lines in verbose mode."""
    content = block.get("content", "")
    is_error = block.get("is_error", False)
    if not content:
        return
    if color:
        c = "\033[31m" if is_error else "\033[2m"
    else:
        c = ""
    yield from _render_capped_lines(content, prefix="    ", cap=30, uncapped=uncapped, color=color, color_override=c)


def _render_capped_lines(text, prefix="", cap=20, uncapped=False, color=True, color_override=None):
    """Yield text lines with optional cap."""
    c = color_override or ("\033[2m" if color else "")
    reset = "\033[0m" if color else ""
    lines = text.splitlines()
    limit = len(lines) if uncapped else cap
    for line in lines[:limit]:
        yield f"  {c}{prefix}{line}{reset}"
    if not uncapped and len(lines) > cap:
        yield f"  {c}{prefix}... ({len(lines) - cap} more lines){reset}"


def _dump_session_for_pane(pane_key):
    """Dump the session for a given pane key to the cache dir."""
    data = read_json(SESSIONS_FILE, default={"panes": {}})
    session = data.get("panes", {}).get(pane_key)
    if not session or not session.get("session_id"):
        return
    session_id = session["session_id"]
    jsonl_path = _find_session_jsonl(PROJECTS_DIR, session_id)
    if jsonl_path:
        _dump_session(jsonl_path)


def _dump_session(jsonl_path):
    """Render a session JSONL to a plain text file in the cache dir with human-readable naming."""
    project_claude_dir = jsonl_path.parent.name
    dir_name = _project_dir_to_short_name(project_claude_dir)
    session_id = jsonl_path.stem
    timestamp = _session_start_timestamp(jsonl_path)
    filename = f"{timestamp}_{session_id}.txt" if timestamp else f"{session_id}.txt"

    out_dir = CMA_CACHE_DIR / dir_name
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / filename
    with open(out_path, 'w') as f:
        for line in _render_session(jsonl_path, verbosity=0, color=False):
            f.write(line + "\n")


def _dump_all_sessions():
    """Dump all sessions that are new or newer than their cached version."""
    existing = _index_cached_sessions()
    count = 0
    for jsonl_path in PROJECTS_DIR.rglob("*.jsonl"):
        session_id = jsonl_path.stem
        cached = existing.get(session_id)
        if cached and cached.stat().st_mtime >= jsonl_path.stat().st_mtime:
            continue
        if cached:
            cached.unlink()
        _dump_session(jsonl_path)
        count += 1
    print(f"Dumped {count} sessions.")


def _index_cached_sessions():
    """Build a map of session_id -> cached txt path for existing dumps."""
    index = {}
    if not CMA_CACHE_DIR.exists():
        return index
    for txt_path in CMA_CACHE_DIR.rglob("*.txt"):
        sid = _extract_session_id(txt_path.stem)
        index[sid] = txt_path
    return index


def _extract_session_id(stem):
    """Extract session UUID from a filename stem, stripping any timestamp prefix."""
    # Format: YYYY-MM-DD_HH_MM_uuid or just uuid
    parts = stem.split("_", 3)
    if len(parts) == 4 and len(parts[0]) == 10 and "-" in parts[0]:
        return parts[3]
    return stem


def _session_start_timestamp(jsonl_path):
    """Read the first timestamp from a JSONL session file."""
    try:
        with open(jsonl_path, 'r') as f:
            for line in f:
                obj = json.loads(line)
                ts = obj.get("timestamp")
                if ts:
                    dt = datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone()
                    return dt.strftime("%Y-%m-%d_%H_%M")
    except (json.JSONDecodeError, OSError, ValueError):
        pass
    return None


def _project_dir_to_short_name(project_dir):
    """Convert a Claude project directory name to a short human-readable name."""
    cwd = _project_dir_to_cwd(project_dir)
    return _format_cwd(cwd)


def _project_dir_to_cwd(project_dir):
    """Convert a Claude project directory name back to a cwd path. Best-effort: picks the longest existing prefix."""
    parts = project_dir.lstrip("-").split("-")
    # Greedily reconstruct the path by checking which splits produce existing directories
    path = "/"
    i = 0
    while i < len(parts):
        # Try joining progressively more parts with "-" to handle dirs with hyphens
        best = None
        for j in range(len(parts), i, -1):
            candidate = os.path.join(path, "-".join(parts[i:j]))
            if os.path.isdir(candidate):
                best = candidate
                i = j
                break
        if best:
            path = best
        else:
            path = os.path.join(path, parts[i])
            i += 1
    return path


def _shell_quote(s):
    """Quote a string for safe use in shell commands."""
    return "'" + s.replace("'", "'\\''") + "'"


#
# Permissions management
#


def list_permissions(**kwargs):
    result = load_project_settings()
    if not result:
        return
    _, _, allow = result
    for perm in allow:
        print(perm)


def lift(**kwargs):
    result = load_project_settings()
    if not result:
        return
    project_settings_path, project_settings, _ = result

    last_permission = project_settings['permissions']['allow'].pop()

    global_settings_path = Path.home() / ".claude" / "settings.json"
    global_settings_path.parent.mkdir(parents=True, exist_ok=True)

    if global_settings_path.exists():
        with open(global_settings_path, 'r') as f:
            global_settings = json.load(f)
    else:
        global_settings = {}

    if 'permissions' not in global_settings:
        global_settings['permissions'] = {}
    if 'allow' not in global_settings['permissions']:
        global_settings['permissions']['allow'] = []

    # Avoid duplicates
    if last_permission not in global_settings['permissions']['allow']:
        global_settings['permissions']['allow'].append(last_permission)

    # Sort global: uppercase before lowercase (ABCZabcz order)
    global_settings['permissions']['allow'].sort(key=lambda s: (s[0].islower(), s))

    # Write both files
    with open(project_settings_path, 'w') as f:
        json.dump(project_settings, f, indent=2)

    with open(global_settings_path, 'w') as f:
        json.dump(global_settings, f, indent=2)

    print(f"✓ Moved to global: {last_permission}")


def load_project_settings():
    """Load project settings, returning (path, settings, allow_list) or None on error."""
    try:
        git_root = sh_read("git rev-parse --show-toplevel 2>/dev/null")
    except subprocess.CalledProcessError:
        git_root = os.getcwd()

    project_settings_path = Path(git_root) / ".claude" / "settings.local.json"
    if not project_settings_path.exists():
        project_settings_path = Path(git_root) / ".claude" / "settings.json"
        if not project_settings_path.exists():
            print(f"Error: No settings file found in {Path(git_root) / '.claude'}")
            return None

    with open(project_settings_path, 'r') as f:
        project_settings = json.load(f)

    allow = project_settings.get('permissions', {}).get('allow', [])
    if not allow:
        print("Error: No permissions found in project settings")
        return None

    return project_settings_path, project_settings, allow


def sh(command):
    subprocess.check_call(['/bin/bash', '-o', 'pipefail', '-c', command])


def sh_read(command):
    return subprocess.check_output(['/bin/bash', '-o', 'pipefail', '-c', command]).decode("utf-8").strip()


def get(li, i, default=None):
    if i < 0 or i >= len(li):
        return default
    return li[i]


