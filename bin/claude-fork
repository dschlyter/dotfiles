#!/bin/bash
# Fork a Claude session from another pane in the current tmux window
set -euo pipefail

SESSION_DIR="/tmp/claude-sessions"

PANES=$(tmux list-panes -t "$(tmux display-message -p '#{window_id}')" -F '#{pane_id}' 2>/dev/null)
if [ -z "$PANES" ]; then
    echo "Error: not in a tmux session" >&2
    exit 1
fi

CURRENT_PANE=$(tmux display-message -p '#{pane_id}')

for pane in $PANES; do
    [ "$pane" = "$CURRENT_PANE" ] && continue
    SESSION_FILE="${SESSION_DIR}/${pane}"
    if [ -f "$SESSION_FILE" ]; then
        SESSION_ID=$(cat "$SESSION_FILE")
        echo "Forking session $SESSION_ID from pane $pane"
        exec claude --resume "$SESSION_ID" --fork-session
    fi
done

echo "Error: no Claude session found in other panes" >&2
exit 1
